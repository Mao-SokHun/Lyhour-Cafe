# Local development — copy to .env and fill in (do not commit .env)
SPRING_PROFILES_ACTIVE=neon
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR-NEON-HOST/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=YOUR_PASSWORD
APP_JWT_SECRET=change-me-to-a-long-random-string
APP_CORS_ALLOWED_ORIGINS=*

# Optional Stripe
APP_STRIPE_ENABLED=false
APP_STRIPE_SECRET_KEY=
APP_STRIPE_WEBHOOK_SECRET=
APP_STRIPE_SUCCESS_URL=http://localhost:8080/order/success?session_id={CHECKOUT_SESSION_ID}
APP_STRIPE_CANCEL_URL=http://localhost:8080/cart?cancelled=true
